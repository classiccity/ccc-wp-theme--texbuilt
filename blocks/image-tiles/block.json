{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/image-tiles",
	"title": "Image Tiles",
	"description": "Grid of image tiles with overlay blurbs and links.",
	"category": "theme",
	"icon": "images-alt2",
	"keywords": [
		"tiles",
		"grid",
		"images"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "auto",
		"renderTemplate": "render.php"
	}
}
