{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/stats",
	"title": "Stats",
	"description": "Row of big-number stats on a brand-gradient background. Admin provides a repeater of value + label pairs.",
	"category": "theme",
	"icon": "chart-bar",
	"keywords": [
		"stats",
		"numbers",
		"metrics",
		"kpi"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "auto",
		"renderTemplate": "render.php"
	}
}
