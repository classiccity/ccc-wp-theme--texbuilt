{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/image-columns",
	"title": "Image Columns",
	"description": "Three-up card grid. Each card has an image, heading, body, and a full-width CTA button.",
	"category": "theme",
	"icon": "grid-view",
	"keywords": [
		"cards",
		"columns",
		"image",
		"grid"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "auto",
		"renderTemplate": "render.php"
	}
}
