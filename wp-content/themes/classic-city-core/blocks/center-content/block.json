{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/center-content",
	"title": "Center Content",
	"description": "Centered copy block with an overhang image and optional background texture.",
	"category": "theme",
	"icon": "align-center",
	"keywords": [
		"center",
		"content",
		"overhang"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"jsx": true,
		"align": [
			"full"
		],
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	}
}
