{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/process-steps",
	"title": "Process Steps",
	"description": "Numbered sequence of steps. Numbers auto-generate from item index.",
	"category": "theme",
	"icon": "editor-ol",
	"keywords": [
		"process",
		"steps",
		"numbered"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "auto",
		"renderTemplate": "render.php"
	}
}
