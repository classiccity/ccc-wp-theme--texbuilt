{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "classic-city-core/cta-large",
	"title": "Large CTA",
	"description": "Full-width call-to-action band with brand color/gradient, optional background image, and InnerBlocks content.",
	"category": "theme",
	"icon": "megaphone",
	"keywords": [
		"cta",
		"call to action",
		"banner"
	],
	"textdomain": "classic-city-core",
	"supports": {
		"html": false,
		"jsx": true,
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"text": false,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": [
				"top",
				"bottom"
			]
		},
		"mode": true
	},
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	}
}
